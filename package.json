{
    "name": "keepling",
    "version": "1.0.1",
    "private": true,
    "scripts": {
        "start": "react-scripts start",
        "build": "react-scripts build",
        "build:staging": "copy .env.stg.example .env.production & npm run build",
        "build:prod": "cp .env.prod.example .env.production && npm run build",
        "build:prod.keeplin": "cp -p .env.prod.example.keeplin .env.production && yarn build",
        "audit": "yarn audit --groups dependencies",
        "outdated": "yarn outdated",
        "serve": "serve -s build",
        "test": "react-scripts test",
        "eject": "react-scripts eject",
        "lint": "eslint .",
        "lint:fix": "eslint --fix --ext .js --ext .ts --ext .jsx --ext .tsx ./src",
        "lint:check-scss": "stylelint-config-prettier-scss-check",
        "lint:scss": "stylelint **/*.scss",
        "lint:fix-scss": "stylelint --fix **/*.scss",
        "icon": "svgr SvgIcons -d src/components/icon/svg-icons --typescript"
    },
    "eslintConfig": {
        "extends": [
            "react-app",
            "react-app/jest"
        ],
        "overrides": [
            {
                "files": [
                    "**/*.stories.*"
                ],
                "rules": {
                    "import/no-anonymous-default-export": "off"
                }
            }
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 4 version",
            ">0.2%"
        ]
    },
